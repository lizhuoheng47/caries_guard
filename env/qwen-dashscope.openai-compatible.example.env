# Qwen via DashScope OpenAI-compatible API.
# Usage:
#   docker compose --env-file env/qwen-dashscope.openai-compatible.example.env up -d --build
#
# Pick ONE base URL (uncomment exactly one):
#   China (Beijing):    CG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   Singapore (Intl):   CG_LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   US (Virginia):      CG_LLM_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# ------------------------------------------------------------------------------
# Java -> Python RAG boundary (keep default unless you moved services)
# ------------------------------------------------------------------------------
CARIES_RAG_BASE_URL=http://backend-python:8001/ai/v1

# ------------------------------------------------------------------------------
# Python: LLM (Chat Completions) - REQUIRED for RAG answers
# ------------------------------------------------------------------------------
CG_LLM_PROVIDER_CODE=DASHSCOPE
CG_LLM_MODEL_NAME=qwen3.6-plus
CG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CG_LLM_API_KEY=sk-26dc741a389a44149e14d3a389314fc7
CG_LLM_TIMEOUT_SECONDS=180

# Optional: if you prefer the official env var name from DashScope docs, you can
# set this instead of CG_LLM_API_KEY. The Python service reads it as fallback.
DASHSCOPE_API_KEY=

# Optional: same idea for base url (fallback for CG_LLM_BASE_URL)
DASHSCOPE_BASE_URL=

# Disable mock fallback in production-like runs
CG_LLM_ENABLE_FALLBACK_MOCK=false
CARIES_RAG_READ_TIMEOUT_MS=240000

# ------------------------------------------------------------------------------
# Python: RAG runtime (knowledge base + retrievers)
# ------------------------------------------------------------------------------
CG_RAG_RUNTIME_ENABLED=true
CG_RAG_VECTOR_STORE_TYPE=OPENSEARCH
CG_RAG_DEFAULT_KB_CODE=kb_clinical_guideline
CG_RAG_DEFAULT_KB_NAME=Caries Clinical Guideline Knowledge Base

# Embeddings:
# DashScope supports OpenAI-compatible embeddings at the same base URL.
CG_RAG_EMBEDDING_PROVIDER=DASHSCOPE
CG_RAG_EMBEDDING_MODEL=text-embedding-v4
CG_RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CG_RAG_EMBEDDING_API_KEY=sk-26dc741a389a44149e14d3a389314fc7
CG_RAG_EMBEDDING_DIMENSION=256
CG_RAG_EMBEDDING_BATCH_SIZE=1

# ------------------------------------------------------------------------------
# Optional: enable analysis->knowledge auto guidance in the analysis pipeline
# ------------------------------------------------------------------------------
CG_ANALYSIS_KB_ENHANCEMENT_ENABLED=true
CG_ANALYSIS_KB_CODE=kb_clinical_guideline
