# Competition demo preset.
# Example: docker compose --env-file env/competition.env up -d --build

CARIES_COMPETITION_MODE_ENABLED=true
CARIES_ANALYSIS_MODEL_VERSION=caries-v1
CG_DEMO_PRESET=competition
CG_DEMO_CASE_SET=default

# Keep the demo preset reproducible and offline-friendly by default.
CG_AI_RUNTIME_MODE=mock
CG_MODEL_QUALITY_ENABLED=false
CG_MODEL_TOOTH_DETECT_ENABLED=false
CG_MODEL_SEGMENTATION_ENABLED=false
CG_MODEL_GRADING_ENABLED=false
CG_MODEL_RISK_ENABLED=false
CG_UNCERTAINTY_REVIEW_THRESHOLD=0.35

CG_RAG_KNOWLEDGE_VERSION=v1.0
CG_LLM_PROVIDER_CODE=MOCK
CG_LLM_MODEL_NAME=template-llm-v1

# -- Advanced Hybrid Mode (Optional) --
# Uncomment these if you wish to run partial real AI evaluation instead of FULL MOCK.
# CG_AI_RUNTIME_MODE=hybrid
# CG_MODEL_QUALITY_ENABLED=true
# CG_MODEL_TOOTH_DETECT_ENABLED=true
