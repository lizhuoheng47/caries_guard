# Competition demo preset.
# Example: docker compose --env-file env/competition.env up -d --build

CARIES_COMPETITION_MODE_ENABLED=true
CARIES_ANALYSIS_MODEL_VERSION=caries-v1
CG_DEMO_PRESET=competition
CG_DEMO_CASE_SET=default

CG_AI_RUNTIME_MODE=real
CG_MODEL_QUALITY_ENABLED=true
CG_MODEL_QUALITY_IMPL_TYPE=HEURISTIC
CG_MODEL_TOOTH_DETECT_ENABLED=true
CG_MODEL_TOOTH_DETECT_IMPL_TYPE=HEURISTIC
CG_MODEL_SEGMENTATION_ENABLED=true
CG_MODEL_SEGMENTATION_IMPL_TYPE=HEURISTIC
CG_MODEL_GRADING_ENABLED=true
CG_MODEL_GRADING_IMPL_TYPE=HEURISTIC
CG_MODEL_RISK_ENABLED=true
CG_MODEL_RISK_IMPL_TYPE=HEURISTIC
CG_MODEL_SEGMENTATION_MANIFEST_PATH=/app/assets/models/manifests/segmentation_v1.yaml
CG_MODEL_GRADING_MANIFEST_PATH=/app/assets/models/manifests/grading_v1.yaml
CG_QUALITY_MODEL_PARAM_PATH=/app/model-weights/quality/quality_model_params.json
CG_UNCERTAINTY_REVIEW_THRESHOLD=0.35

CG_RAG_RUNTIME_ENABLED=true
CG_RAG_KNOWLEDGE_VERSION=v1.0-demo
CG_RAG_DEFAULT_KB_CODE=caries-default
CG_RAG_DEFAULT_KB_NAME=CariesGuard Competition Demo Knowledge
CG_RAG_VECTOR_STORE_TYPE=OPENSEARCH
CG_RAG_EMBEDDING_PROVIDER=DASHSCOPE
CG_RAG_EMBEDDING_MODEL=text-embedding-v4
CG_RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CG_RAG_EMBEDDING_API_KEY=sk-26dc741a389a44149e14d3a389314fc7
CG_RAG_EMBEDDING_DIMENSION=256
CG_RAG_EMBEDDING_BATCH_SIZE=1

CG_LLM_PROVIDER_CODE=DASHSCOPE
CG_LLM_MODEL_NAME=qwen3.6-plus
CG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CG_LLM_API_KEY=sk-26dc741a389a44149e14d3a389314fc7
CG_LLM_TIMEOUT_SECONDS=180
CG_LLM_ENABLE_FALLBACK_MOCK=false
CARIES_RAG_READ_TIMEOUT_MS=240000
CG_ANALYSIS_KB_ENHANCEMENT_ENABLED=true
CG_ANALYSIS_KB_CODE=caries-default
