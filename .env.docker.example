# ==============================================================================
# DEV ENVIRONMENT TEMPLATE
# Copy to .env if you want to override Docker Compose DEV defaults.
# THIS FILE IS STRICTLY FOR LOCAL DEVELOPMENT/INTEGRATION (CARIES_COMPETITION_MODE_ENABLED=false)
# FOR STANDARD DEMOS/COMPETITION, DO NOT USE `.env`. INSTEAD, USE:
#   env/competition.env
# ==============================================================================

# -- Database -----------------------------------------------------------
CARIES_MYSQL_PASSWORD=1234
CARIES_MYSQL_DATABASE_BIZ=caries_biz
CARIES_MYSQL_DATABASE_AI=caries_ai
CARIES_MYSQL_HOST_PORT=13306
CARIES_FLYWAY_CLEAN_ON_VALIDATION_ERROR=false
CARIES_FLYWAY_CLEAN_DISABLED=true

# -- Cache / MQ ---------------------------------------------------------
CARIES_REDIS_HOST_PORT=16379
CARIES_RABBIT_USERNAME=guest
CARIES_RABBIT_PASSWORD=guest
CARIES_RABBIT_HOST_PORT=5672
CARIES_RABBIT_MGMT_HOST_PORT=15672

# -- Object Storage -----------------------------------------------------
CARIES_MINIO_ACCESS_KEY=minioadmin
CARIES_MINIO_SECRET_KEY=minioadmin
CARIES_MINIO_HOST_PORT=9000
CARIES_MINIO_CONSOLE_HOST_PORT=9001
CARIES_BUCKET_IMAGE=caries-image
CARIES_BUCKET_VISUAL=caries-visual
CARIES_BUCKET_REPORT=caries-report
CARIES_BUCKET_EXPORT=caries-export

# -- Java Business Chain ------------------------------------------------
CARIES_BACKEND_JAVA_HOST_PORT=8080
CARIES_STORAGE_AUTO_CREATE_BUCKETS=false
CARIES_IMAGE_ACCESS_SECRET=docker-change-me-to-a-strong-image-access-secret
CARIES_ANALYSIS_CALLBACK_SECRET=docker-change-me-to-a-strong-analysis-callback-secret

# -- Competition Mode ---------------------------------------------------
# Keep false in the shared example. Use env/competition.env for demo preset.
CARIES_COMPETITION_MODE_ENABLED=false

# -- Demo / Knowledge ---------------------------------------------------
CARIES_ANALYSIS_MODEL_VERSION=caries-v1
CG_CALLBACK_VISUAL_ASSET_MODE=metadata
CG_RAG_INDEX_DIR=/tmp/cariesguard/vector-index

# MUST KEEP as v1.0 and MOCK for normal competition demos. Only change for local dev.
CG_RAG_KNOWLEDGE_VERSION=v1.0
CG_LLM_PROVIDER_CODE=MOCK
CG_LLM_MODEL_NAME=template-llm-v1
CG_RAG_TOP_K=5
CG_RAG_LEXICAL_TOP_K=20
CG_RAG_DENSE_TOP_K=20
CG_RAG_GRAPH_TOP_K=10
CG_RAG_FUSION_TOP_K=12
CG_RAG_RERANK_TOP_K=8
CG_RAG_ANSWER_EVIDENCE_TOP_K=6
CG_RAG_RERANK_PROVIDER=EMBEDDING
CG_RAG_RERANK_MODEL_NAME=embedding-similarity-reranker
CG_RAG_RERANK_BASE_URL=
CG_RAG_RERANK_API_KEY=
CG_RAG_RERANK_TIMEOUT_SECONDS=20
CG_LLM_HEDGE_ENABLED=false
CG_LLM_HEDGE_DELAY_MS=250
CG_LLM_HEDGE_PROVIDER_CODE=
CG_LLM_HEDGE_MODEL_NAME=
CG_LLM_HEDGE_BASE_URL=
CG_LLM_HEDGE_API_KEY=
CG_LLM_SCENE_ROUTING_ENABLED=false
CG_LLM_DOCTOR_PROVIDER_CODE=
CG_LLM_DOCTOR_MODEL_NAME=
CG_LLM_DOCTOR_BASE_URL=
CG_LLM_DOCTOR_API_KEY=
CG_LLM_PATIENT_PROVIDER_CODE=
CG_LLM_PATIENT_MODEL_NAME=
CG_LLM_PATIENT_BASE_URL=
CG_LLM_PATIENT_API_KEY=
CG_LLM_TIMEOUT_SECONDS=30
CG_LLM_RETRY_COUNT=1
CG_LLM_TEMPERATURE=0.2
CG_LLM_ENABLE_FALLBACK_MOCK=true
CARIES_RAG_READ_TIMEOUT_MS=10000
CG_QWEN_VISION_ENABLED=false
CG_QWEN_VISION_MODEL=qwen3-vl-plus
CG_QWEN_VISION_BASE_URL=http://placeholder.invalid/v1
CG_QWEN_VISION_API_KEY=placeholder
CG_ANALYSIS_KB_ENHANCEMENT_ENABLED=false
CG_ANALYSIS_KB_CODE=caries-default

# -- AI Runtime ---------------------------------------------------------
# mock   - all modules use mock (default, safe for development)
# hybrid - enabled modules use real adapters, others use mock
# real   - all modules must use real adapters; failures are NOT silently downgraded
CG_AI_RUNTIME_MODE=mock
CG_MODEL_QUALITY_ENABLED=false
CG_MODEL_TOOTH_DETECT_ENABLED=false
CG_MODEL_SEGMENTATION_ENABLED=false
CG_MODEL_GRADING_ENABLED=false
CG_MODEL_RISK_ENABLED=false
CG_MODEL_DEVICE=cpu
CG_MODEL_WEIGHTS_DIR=/app/model-weights
CG_MODEL_CONFIDENCE_THRESHOLD=0.5
CG_SEGMENTATION_FORCE_FAIL=false
CG_GRADING_FORCE_FAIL=false
CG_UNCERTAINTY_REVIEW_THRESHOLD=0.35
