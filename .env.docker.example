# Copy to .env if you want to override Docker Compose defaults.
CARIES_MYSQL_PASSWORD=1234
CARIES_MYSQL_DATABASE=cg
CARIES_MYSQL_HOST_PORT=13306
# Keep false unless you intentionally want Flyway to clean an incompatible old dev database.
CARIES_FLYWAY_CLEAN_ON_VALIDATION_ERROR=false
CARIES_FLYWAY_CLEAN_DISABLED=true

CARIES_REDIS_HOST_PORT=16379

CARIES_RABBIT_USERNAME=guest
CARIES_RABBIT_PASSWORD=guest
CARIES_RABBIT_HOST_PORT=5672
CARIES_RABBIT_MGMT_HOST_PORT=15672

CARIES_MINIO_ACCESS_KEY=minioadmin
CARIES_MINIO_SECRET_KEY=minioadmin
CARIES_MINIO_HOST_PORT=9000
CARIES_MINIO_CONSOLE_HOST_PORT=9001
CARIES_BUCKET_IMAGE=caries-image
CARIES_BUCKET_VISUAL=caries-visual
CARIES_BUCKET_REPORT=caries-report
CARIES_BUCKET_EXPORT=caries-export

CARIES_BACKEND_JAVA_HOST_PORT=8080
# Docker profile expects MinIO buckets to be created by minio-init.
CARIES_STORAGE_AUTO_CREATE_BUCKETS=false
# Used to sign /api/v1/files/{attachmentId}/content proxy access links.
CARIES_IMAGE_ACCESS_SECRET=docker-change-me-to-a-strong-image-access-secret
CARIES_ANALYSIS_CALLBACK_SECRET=docker-change-me-to-a-strong-analysis-callback-secret
CARIES_ANALYSIS_MODEL_VERSION=caries-v1
CG_CALLBACK_VISUAL_ASSET_MODE=metadata
CG_RAG_INDEX_DIR=/tmp/cariesguard/vector-index
